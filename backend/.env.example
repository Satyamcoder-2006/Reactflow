# Backend Environment Variables

# ==============================================
# 📦 STORAGE CONFIGURATION (Local File System)
# ==============================================
# Files are stored locally in the "uploads" directory.
# Ensure your deployment (VPS/Docker) persists this volume!
# ❌ NOT compatible with Serverless (Vercel/Lambda) ephemeral storage.

# URL where backend is accessible (to serve files via /storage)
BACKEND_URL="http://localhost:3001"

# ==============================================
# 🗄️ DATABASE (PostgreSQL)
# ==============================================
# Use credentials from docker-compose.yml
DATABASE_URL="postgresql://reactflow:reactflow_dev_password@localhost:5432/reactflow?schema=public"

# ==============================================
# 🚀 REDIS (Message Queue)
# ==============================================
REDIS_HOST="localhost"
REDIS_PORT=6379

# ==============================================
# ⚡ SERVER CONFIG
# ==============================================
PORT=3001
HOST="0.0.0.0"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

# JWT Secret (generate a strong random string like `openssl rand -hex 32`)
JWT_SECRET="super-secret-jwt-key-change-this-in-production"

# ==============================================
# 🐙 GITHUB INTEGRATION
# ==============================================
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"
# github.com/settings/apps -> Private Key
GITHUB_APP_PRIVATE_KEY=""
GITHUB_APP_ID=""

# ==============================================
# 🏗️ BUILD SYSTEM
# ==============================================
# Max concurrent builds (CPU intensive)
MAX_CONCURRENT_BUILDS=2

# ==============================================
1. 🏗️ EMULATOR CONFIGURATION
# ==============================================
# Path to ADB (Android Debug Bridge)
# Windows: C:\path\to\platform-tools\adb.exe
# Linux/WSL: adb or /usr/bin/adb
ADB_PATH="C:\Users\satya\platform-tools-latest-windows\platform-tools\adb.exe"

# Path to Scrcpy (Screen Copy)
# Windows: C:\path\to\scrcpy\scrcpy.exe
# Linux/WSL: scrcpy or /usr/local/bin/scrcpy
SCRCPY_PATH="C:\Users\satya\scrcpy-win64-v2.3.1\scrcpy-win64-v2.3.1\scrcpy.exe"

# Redroid Container Settings
REDROID_WIDTH=412
REDROID_HEIGHT=892
REDROID_FPS=30
REDROID_ADB_PORT=5555

# Network and Storage
EMULATOR_NETWORK="reactflow_emulator"
APK_TEMP_DIR="C:\Users\satya\reactflow-apks"
